# Rust
/target
**/*.rs.bk
*.pdb

# Node
node_modules
/dist
*.tsbuildinfo
npm-debug.log*

# Native build outputs (produced by CI / local build, not committed)
/prebuilds
*.node

# Logs / scratch
build-native.log
*.log

# Editor / OS
.DS_Store
.idea
